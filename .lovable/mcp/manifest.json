{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://yonrotcqgphylkshgfiv.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "mealops-mcp",
      "version": "0.1.0",
      "title": "MealOps"
    },
    "tools": [
      {
        "name": "list_menu_week",
        "title": "List weekly mess menu",
        "description": "Return the full 7-day Sri Sairam College mess menu grouped by day and meal (breakfast, lunch, snacks, dinner) with nutrition per dish.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "get_todays_menu",
        "title": "Get today's mess menu",
        "description": "Return today's mess menu (breakfast, lunch, snacks, dinner) with timings and nutrition per dish.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "$schema": "http://json-schema.org/draft-07/schema#",
          "type": "object",
          "properties": {}
        },
        "outputSchema": null
      },
      {
        "name": "log_meal",
        "title": "Log a meal",
        "description": "Log a food item the signed-in user ate today (or on a given date) with its nutrition. Use for tracking what the user consumed.",
        "annotations": {
          "readOnlyHint": false,
          "destructiveHint": false,
          "idempotentHint": false,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "meal_type": {
              "type": "string",
              "enum": [
                "breakfast",
                "lunch",
                "snacks",
                "dinner"
              ]
            },
            "item_name": {
              "type": "string",
              "minLength": 1,
              "description": "Name of the dish, e.g. 'Chicken Biryani'."
            },
            "calories": {
              "type": "integer",
              "minimum": 0,
              "description": "kcal"
            },
            "protein": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "grams"
            },
            "carbs": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "grams"
            },
            "fat": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "grams"
            },
            "fiber": {
              "type": "number",
              "minimum": 0,
              "default": 0,
              "description": "grams"
            },
            "log_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "YYYY-MM-DD; defaults to today"
            }
          },
          "required": [
            "meal_type",
            "item_name",
            "calories"
          ],
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_my_meal_logs",
        "title": "List my meal logs",
        "description": "Return the signed-in user's logged meals for a date range (default: last 7 days), ordered newest first.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "from_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "YYYY-MM-DD, inclusive"
            },
            "to_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "YYYY-MM-DD, inclusive"
            },
            "limit": {
              "type": "integer",
              "exclusiveMinimum": 0,
              "maximum": 200,
              "default": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "get_todays_nutrition",
        "title": "Get today's nutrition totals",
        "description": "Summed calories/protein/carbs/fat/fiber for the signed-in user's meal logs on a given date (default: today).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "log_date": {
              "type": "string",
              "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
              "description": "YYYY-MM-DD; defaults to today"
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
